# ── Supabase ─────────────────────────────────────────────────────────────
# Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key (server-only). Used by the seed script and to cache AI
# previews on behalf of anonymous public viewers. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Anthropic (optional) ─────────────────────────────────────────────────
# If set, matchup previews are written by Claude (Haiku). If omitted, the app
# falls back to deterministic templated previews — it never breaks without it.
ANTHROPIC_API_KEY=
